<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive-icon background: a diagonal warm-brown gradient, darker at the
  top-left and lighter toward the bottom-right, giving the tile the same
  subtle depth as the iOS / macOS md app icon (sampled #1F1812 → #3C3024).
  The mid tone is the shared brand brown from colors.xml. The cream "md"
  glyph is drawn on top by @mipmap/ic_launcher_foreground, sized to sit
  inside the adaptive safe zone so no launcher mask clips it.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:type="linear"
        android:angle="315"
        android:startColor="#1F1812"
        android:centerColor="@color/ic_launcher_background"
        android:endColor="#3C3024" />
</shape>
